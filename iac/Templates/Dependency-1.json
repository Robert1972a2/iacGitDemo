{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {},
    "functions": [],
    "variables": {
        
    },
    "resources": [
        {
            "name": "iac-NIC-1",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2024-03-01",
            "location": "[resourceGroup().location]",
            "tags": {
                "Owner": "DIST",
                "Course": "IaC"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', 'iac-VNet-Spoke-1')]"
            ],
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipConfig1",
                        "properties": {
                            "privateIPAllocationMethod": "Dynamic",
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'iac-VNet-Spoke-1', 'SubnetTier1')]"
                            }
                        }
                    }
                ]
            }
        },
        {
            "name": "iac-VNet-Spoke-1",
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2024-05-01",
            "location": "[resourceGroup().location]",
            "tags": {
                "Owner": "DIST",
                "Course": "IaC"
            },
                        "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.100.0.0/16"
                    ]
                },
                "subnets": [
                    {
                        "name": "SubnetTier1",
                        "properties": {
                            "addressPrefix": "10.100.0.0/24"
                        }
                    },
                    {
                        "name": "SubnetTier2",
                        "properties": {
                            "addressPrefix": "10.100.1.0/24"
                        }
                    }
                ]
            }
        }
    ],
    "outputs": {}
}