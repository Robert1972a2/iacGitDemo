{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "saName": {
            "type": "string",
            "metadata": {
                "description": "Name of the storage account to create."
            }
        },
        "location": {
            "type": "string",
            "metadata": {
                "description": "Location for the storage account."
            },
            "allowedValues": [
                "GermanyWestCentral",
                "NorthEurope",
                "WestEurope",
                "AustriaEast"
            ]
        }
    },
    "functions": [],
    "variables": {
        "saNameComplete": "[concat(parameters('saName'), uniqueString(resourceGroup().id))]"
    },
    "resources": [
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2024-01-01",
            "name": "[variables('saNameComplete')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "accessTier": "Cool"
            }
        }
    ],
    "outputs": {}
}